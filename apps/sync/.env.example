# Copy to .env.local for local dev. In production set these on the host
# (Railway/Render) instead. These MUST match the web app's values.

# Same secret the web app signs sessions/sync-tokens with — used to verify
# the ?token on incoming WebSocket connections.
AUTH_SECRET=""

# Same Neon Postgres connection string the web app uses — for membership/role
# checks and Yjs snapshot persistence.
DATABASE_URL=""

# Port to listen on (defaults to 1234; the host usually injects PORT).
SYNC_PORT=1234
