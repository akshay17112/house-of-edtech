{
  "name": "house-of-edtech",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first collaborative document editor with offline sync, deterministic CRDT conflict resolution, and version history.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p apps/sync/tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
